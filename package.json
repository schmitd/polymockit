{
  "name": "polymockit",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.8",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "bun --filter @polymockit/web dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck && bun run typecheck:convex",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "lint": "turbo run lint",
    "convex:dev": "bunx convex dev",
    "convex:deploy": "bunx convex deploy"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "convex": "^1.32.0",
    "turbo": "^2.8.10",
    "typescript": "^5.8.3"
  }
}
